{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "packages": {
    ".": {
      "release-type": "node",
      "component": "eslint-config-setup",
      "package-name": "eslint-config-setup",
      "changelog-path": "packages/eslint-config/CHANGELOG.md",
      "exclude-paths": ["docs"],
      "extra-files": [
        {
          "type": "json",
          "path": "packages/eslint-config/package.json",
          "jsonpath": "$.version"
        }
      ]
    },
    "packages/eslint-config-cli": {
      "release-type": "node",
      "component": "eslint-config-setup-cli",
      "package-name": "eslint-config-setup-cli",
      "changelog-path": "packages/eslint-config-cli/CHANGELOG.md",
      "exclude-paths": ["docs"],
      "extra-files": [
        {
          "type": "json",
          "path": "packages/eslint-config-cli/package.json",
          "jsonpath": "$.version"
        }
      ]
    }
  }
}
