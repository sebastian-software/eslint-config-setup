{
  "name": "eslint-config-setup",
  "version": "0.4.0",
  "description": "Pre-generated, permutation-based ESLint flat configs for modern TypeScript & React projects",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./modules": {
      "types": "./dist/modules.d.ts",
      "import": "./dist/modules.js"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "check": "tsc --noEmit",
    "build": "tsup",
    "generate": "node --import tsx src/build/generate.ts",
    "prepublishOnly": "npm run build && npm run generate",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "eslint",
    "eslintconfig",
    "typescript",
    "react",
    "flat-config",
    "oxlint"
  ],
  "author": {
    "name": "Sebastian Software GmbH",
    "url": "https://sebastian-software.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sebastian-software/eslint-config-setup.git",
    "directory": "packages/eslint-config"
  },
  "homepage": "https://sebastian-software.github.io/eslint-config-setup/",
  "bugs": {
    "url": "https://github.com/sebastian-software/eslint-config-setup/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/sebastian-software"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "sideEffects": false,
  "peerDependencies": {
    "eslint": ">=10",
    "typescript": ">= 5.0"
  },
  "dependencies": {
    "@cspell/eslint-plugin": "^10.0.0",
    "@eslint-react/eslint-plugin": "^5.6.0",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.2.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@vitest/eslint-plugin": "^1.6.16",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-compat": "^7.0.1",
    "eslint-plugin-de-morgan": "^2.1.1",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-mdx": "^3.7.0",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-oxlint": "^1.61.0",
    "eslint-plugin-package-json": "^0.91.1",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-playwright": "^2.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-react-you-might-not-need-an-effect": "^0.9.3",
    "eslint-plugin-regexp": "^3.1.0",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-storybook": "^10.3.5",
    "eslint-plugin-testing-library": "^7.16.2",
    "eslint-plugin-unicorn": "^64.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.5.0",
    "typescript-eslint": "^8.59.0"
  },
  "devDependencies": {
    "@oxlint/migrate": "^1.61.0",
    "@types/node": "^25.6.0",
    "@types/picomatch": "^4.0.3",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.1",
    "oxlint": "^1.61.0",
    "picomatch": "^4.0.4",
    "storybook": "^10.3.5",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
