{
  "name": "eslint-config-setup",
  "version": "0.1.0",
  "description": "Pre-generated, permutation-based ESLint flat configs for modern TypeScript & React projects",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./modules": {
      "types": "./dist/modules.d.ts",
      "import": "./dist/modules.js"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsup",
    "generate": "node --import tsx src/build/generate.ts",
    "prepublishOnly": "npm run build && npm run generate",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "eslint",
    "eslintconfig",
    "typescript",
    "react",
    "flat-config",
    "oxlint"
  ],
  "author": {
    "name": "Sebastian Software GmbH",
    "url": "https://sebastian-software.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sebastian-software/eslint-config-setup.git",
    "directory": "packages/eslint-config"
  },
  "homepage": "https://github.com/sebastian-software/eslint-config-setup/tree/main/packages/eslint-config",
  "bugs": {
    "url": "https://github.com/sebastian-software/eslint-config-setup/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/sebastian-software"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "sideEffects": false,
  "peerDependencies": {
    "eslint": ">= 9.22",
    "typescript": ">= 5.0"
  },
  "dependencies": {
    "@cspell/eslint-plugin": "^9.7.0",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.0.0",
    "@vitest/eslint-plugin": "^1.6.0",
    "eslint-config-prettier": "^10.1.0",
    "eslint-plugin-de-morgan": "^2.1.0",
    "eslint-plugin-import-x": "^4.6.0",
    "eslint-plugin-jsdoc": "^62.7.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-mdx": "^3.2.0",
    "eslint-plugin-n": "^17.15.0",
    "eslint-plugin-package-json": "^0.89.0",
    "eslint-plugin-oxlint": "^1.51.0",
    "eslint-plugin-perfectionist": "^5.6.0",
    "eslint-plugin-playwright": "^2.9.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-react-refresh": "^0.5.0",
    "eslint-plugin-react-you-might-not-need-an-effect": "^0.9.0",
    "eslint-plugin-regexp": "^3.0.0",
    "eslint-plugin-security": "^4.0.0",
"eslint-plugin-sonarjs": "^4.0.0",
    "eslint-plugin-storybook": "^10.2.14",
    "eslint-plugin-testing-library": "^7.1.0",
    "eslint-plugin-unicorn": "^63.0.0",
    "eslint-plugin-unused-imports": "^4.1.0",
    "globals": "^17.4.0",
    "typescript-eslint": "^8.20.0"
  },
  "devDependencies": {
    "@oxlint/migrate": "^1.51.0",
    "@types/node": "^25.3.3",
    "eslint": "^10.0.2",
    "eslint-plugin-compat": "^7.0.0",
    "oxlint": "^1.51.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "@vitest/coverage-v8": "^4.0.18",
    "vitest": "^4.0.18"
  }
}
