{
  "name": "eslint-config-setup-monorepo",
  "private": true,
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "Sebastian Software GmbH",
    "url": "https://sebastian-software.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sebastian-software/eslint-config-setup.git"
  },
  "homepage": "https://sebastian-software.github.io/eslint-config-setup/",
  "bugs": {
    "url": "https://github.com/sebastian-software/eslint-config-setup/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/sebastian-software"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm --filter eslint-config-setup build",
    "check": "pnpm --filter eslint-config-setup check",
    "generate": "pnpm --filter eslint-config-setup generate",
    "test": "pnpm --filter eslint-config-setup test",
    "test:coverage": "pnpm --filter eslint-config-setup test:coverage",
    "lint": "pnpm lint:self && pnpm lint:docs",
    "lint:self": "node --import tsx node_modules/eslint/bin/eslint.js --no-config-lookup --config eslint.config.js .",
    "lint:docs": "node --import tsx node_modules/eslint/bin/eslint.js --no-config-lookup --config docs/eslint.config.js docs/app docs/react-router.config.ts docs/vite.config.ts",
    "prepare": "git config --local core.hooksPath .githooks || true",
    "docs:dev": "pnpm --filter docs dev",
    "docs:build": "pnpm --filter docs build"
  },
  "devDependencies": {
    "eslint": "^10.1.0",
    "eslint-config-setup": "workspace:*",
    "jiti": "^2.6.1",
    "tsx": "^4.21.0"
  },
  "version": "0.3.3"
}
